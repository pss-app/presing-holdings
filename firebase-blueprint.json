{
  "entities": {
    "Contact": {
      "title": "Contact",
      "description": "一般お問い合わせ情報",
      "type": "object",
      "properties": {
        "companyName": { "type": "string", "description": "会社名" },
        "name": { "type": "string", "description": "氏名" },
        "email": { "type": "string", "format": "email", "description": "メールアドレス" },
        "content": { "type": "string", "description": "お問い合わせ内容" },
        "createdAt": { "type": "string", "format": "date-time", "description": "作成日時" }
      },
      "required": ["companyName", "name", "email", "content", "createdAt"]
    },
    "Job": {
      "title": "Job",
      "description": "採用案件情報",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "案件名" },
        "description": { "type": "string", "description": "案件詳細" },
        "requirements": { "type": "string", "description": "応募要件" },
        "location": { "type": "string", "description": "勤務地" },
        "salary": { "type": "string", "description": "給与条件" },
        "employmentType": { "type": "string", "description": "雇用形態" },
        "status": { "type": "string", "enum": ["active", "closed"], "description": "募集ステータス" },
        "createdAt": { "type": "string", "format": "date-time", "description": "作成日時" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "更新日時" }
      },
      "required": ["title", "description", "location", "employmentType", "status", "createdAt"]
    },
    "Recruit": {
      "title": "Recruit",
      "description": "採用エントリー情報",
      "type": "object",
      "properties": {
        "jobId": { "type": "string", "description": "応募案件ID" },
        "name": { "type": "string", "description": "氏名" },
        "email": { "type": "string", "format": "email", "description": "メールアドレス" },
        "phone": { "type": "string", "description": "電話番号" },
        "jobTitle": { "type": "string", "description": "希望職種（自由入力）" },
        "employmentType": { "type": "string", "description": "希望雇用形態" },
        "desiredSalary": { "type": "string", "description": "希望給与" },
        "workLocation": { "type": "string", "description": "希望勤務地" },
        "experience": { "type": "string", "description": "職務経歴・スキル" },
        "availableFrom": { "type": "string", "description": "入社可能時期" },
        "selfPr": { "type": "string", "description": "自己PR" },
        "status": { "type": "string", "enum": ["pending", "interviewing", "hired", "rejected"], "description": "選考ステータス" },
        "createdAt": { "type": "string", "format": "date-time", "description": "作成日時" }
      },
      "required": ["name", "email", "phone", "createdAt"]
    }
  },
  "firestore": {
    "/contacts/{contactId}": {
      "schema": "Contact",
      "description": "お問い合わせ情報の保存先"
    },
    "/jobs/{jobId}": {
      "schema": "Job",
      "description": "採用案件情報の保存先"
    },
    "/recruits/{recruitId}": {
      "schema": "Recruit",
      "description": "採用エントリー情報の保存先"
    }
  }
}
